@model List<MVC_form_Valid_Error.Models.Cliente>

<h2>Lista de Clientes</h2>

<a asp-action="Crear" class="btn btn-primary">Nuevo Cliente</a>

<table class="table">
	<tr>
		<th>Nombre</th>
		<th>Email</th>
		<th></th>
	</tr>

	@foreach (var c in Model)
	{
		<tr>
			<td>@c.Nombre</td>
			<td>@c.Email</td>
			<td>
				<a asp-action="Detalle" asp-route-id="@c.Id">Ver</a>
			</td>
		</tr>
	}

</table>